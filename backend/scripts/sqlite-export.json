      "id": 1,
      "title": "Pilar Group",
      "slug": "pilar-group",
      "short_description": "Centralized internal platform and SSO gateway for all Pilar Group web applications.",
      "description": "Pilar Group is the backbone of PT Pilar Niaga Makmur's internal digital ecosystem. It serves as the main dashboard and single sign-on entry point — users authenticate once and get access to all connected internal tools without logging in again. The platform manages JWT-based auth for most services and delegates SAML-based auth for some project.",
      "tech_stack": "[\"Laravel\",\"React.js\",\"JWT & SAML Auth\",\"MySQL\",\"Compute Engine\"]",

    {
      "id": 2,
      "title": "Treeview",
      "slug": "treeview",
      "short_description": "Internal revenue analytics dashboard powered by BigQuery for real-time business insights.",
      "description": "Treeview is an internal data analytics platform built for PT Pilar Niaga Makmur's management team to monitor and analyze company revenue. It connects directly to Google BigQuery as the data source, pulling large-scale transactional data and presenting it through interactive filters and visualizations within the web app. Enables the team to slice revenue data by various dimensions without needing direct access to raw query tools. Hosted on Google Cloud Platform alongside Pilar Group.",
      "tech_stack": "[\"Laravel\",\"React.js\",\"BigQuery\",\"JWT & SAML Auth\",\"Compute Engine\"]",

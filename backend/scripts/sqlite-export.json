    {
      "id": 3,
      "title": "Touchpoint",
      "slug": "touchpoint",
      "short_description": "Sales activity tracker with location logging for customer visits and follow-ups.",
      "description": "Touchpoint is an internal CRM-like tool built for the sales team at PT Pilar Niaga Makmur to record and monitor their field activities. Sales reps can log customer visits and follow-up interactions directly from the app, with location data captured at the time of entry. Managers get visibility into team activity and geographic coverage. Integrated with Pilar Group's central auth via JWT. Hosted on Google Cloud Platform.",
      "tech_stack": "[\"Laravel\",\"React.js\",\"JWT & SAML Auth\",\"MySQL\",\"Compute Engine\"]",
